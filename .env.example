APP_NAME=Deep Bleue IA DocMind
APP_ENV=dev
API_V1_PREFIX=/api/v1

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://docmind:docmind@localhost:5432/docmind

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=docmind_chunks

# Redis / RQ
REDIS_URL=redis://localhost:6379/0

# Embeddings and LLM providers
# provider values: mock, openai
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o
OPENAI_API_KEY=

# Dev auth. Never enable in production.
DEV_AUTH_ENABLED=true
DEFAULT_TENANT_ID=deep-bleue-ia

# Local connector used by the MVP.
LOCAL_CONNECTOR_ROOT=./sample_docs

# Retrieval
RAG_TOP_K=8
RAG_MAX_CONTEXT_CHARS=12000
